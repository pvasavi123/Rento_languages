{
  "expo": {
    "name": "Rennto",
    "slug": "rennto",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rennto",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "end",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Rennto to access your photos so you can upload payment screenshots."
      }
    },
    "android": {
      "package": "in.rennto.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/rent2.png"


        // "backgroundColor": "#E6F4FE",
        // "foregroundImage": "./assets/images/rent2.png",
        // "backgroundImage": "./assets/images/rent2.png",
        // "monochromeImage": "./assets/images/rent2.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "platforms": [
      "android",
      "ios"
    ],
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/rent2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        } 
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/rent2.png",
          "color": "#5F259F"
        }
      ],
      "expo-audio",
      "expo-asset",
      "./withUCropString.js"
    ],
    "experiments": {
  "typedRoutes": true,
  "reactCompiler": false
},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49d33ae2-fdfa-4eb7-bd07-89a8c8a4e8bb"
      }
    },
    "owner": "mohammad-arif"
  }
}
